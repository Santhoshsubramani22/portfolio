<script>
// ===== Typing Effect =====
const typedText=[
"Data Scientist",
"Machine Learning Engineer",
"AI Developer",
"Cybersecurity Enthusiast",
"Big Data Analyst"
];
//const typedText=["Data Scientist","ML Engineer","AI Developer","Big Data Analyst"];
let i=0,j=0,current="",isDeleting=false;
const typeEl=document.getElementById("typing");
function type(){
  if(i>=typedText.length)i=0;
  let full=typedText[i];
  current=isDeleting?full.substring(0,--j):full.substring(0,++j);
  typeEl.textContent=current;
  if(!isDeleting && j===full.length+1){isDeleting=true;setTimeout(type,1000);}
  else if(isDeleting && j===0){isDeleting=false;i++;setTimeout(type,500);}
  else setTimeout(type,isDeleting?50:100);
}
type();

// ===== Scroll Animation =====
const sections=document.querySelectorAll("section");
window.addEventListener("scroll",()=>{
  sections.forEach(sec=>{
    const rect=sec.getBoundingClientRect();
    if(rect.top<window.innerHeight-100){sec.classList.add("show");}
  });
});
</script>
